<Window x:Class="SecureCloud.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SecureCloud - Encrypted Cloud Storage" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0" Margin="5">
            <Button Command="{Binding InitializeCommand}" 
                    Content="Initialize" 
                    IsEnabled="{Binding IsInitialized, Converter={StaticResource InverseBooleanConverter}}"
                    Margin="2"/>
            <Separator/>
            <Button Command="{Binding AddFileCommand}" 
                    Content="Add File" 
                    IsEnabled="{Binding IsInitialized}"
                    Margin="2"/>
            <Button Command="{Binding AddWatchedFolderCommand}" 
                    Content="Watch Folder" 
                    IsEnabled="{Binding IsInitialized}"
                    Margin="2"/>
            <Separator/>
            <Button Command="{Binding SyncPendingUploadsCommand}" 
                    Content="Sync Uploads" 
                    IsEnabled="{Binding IsInitialized}"
                    Margin="2"/>
            <Button Command="{Binding RefreshSyncStatusCommand}" 
                    Content="Refresh" 
                    IsEnabled="{Binding IsInitialized}"
                    Margin="2"/>
        </ToolBar>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Margin="5">
            
            <!-- Files Tab -->
            <TabItem Header="Files">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0" 
                              ItemsSource="{Binding Files}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeFormatted}" Width="100"/>
                            <DataGridTextColumn Header="Modified" Binding="{Binding LastModified, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="150"/>
                            <DataGridCheckBoxColumn Header="Uploaded" Binding="{Binding IsUploaded}" Width="80"/>
                            <DataGridTemplateColumn Header="Actions" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Download" 
                                                Command="{Binding DataContext.DownloadFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="5,2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="1" 
                               Text="No files added yet" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               FontStyle="Italic"
                               Foreground="Gray"
                               Visibility="{Binding Files.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                </Grid>
            </TabItem>

            <!-- Watched Folders Tab -->
            <TabItem Header="Watched Folders">
                <Grid>
                    <ListBox ItemsSource="{Binding WatchedFolders}"
                             Margin="5">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding}" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="Remove" Margin="5,0,0,0" Padding="5,2"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- Sync Status Tab -->
            <TabItem Header="Sync Status">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Files:" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SyncStatus.TotalFiles}" Margin="0,5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Total Size:" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SyncStatus.TotalSizeFormatted}" Margin="0,5"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Pending Chunks:" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SyncStatus.PendingChunks}" Margin="0,5"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Last Sync:" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SyncStatus.LastSync, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Margin="0,5"/>

                    <Border Grid.Row="4" Grid.ColumnSpan="2" 
                            Background="LightYellow" 
                            BorderBrush="Orange" 
                            BorderThickness="1" 
                            CornerRadius="3" 
                            Padding="10" 
                            Margin="0,10,0,0"
                            Visibility="{Binding SyncStatus.HasPendingUploads, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="⚠️ Pending Uploads" FontWeight="Bold" Foreground="DarkOrange"/>
                            <TextBlock Text="Some files have not been uploaded to Telegram yet. Click 'Sync Uploads' to upload them." 
                                       TextWrapping="Wrap" 
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <ProgressBar Width="100" 
                                 Height="16" 
                                 IsIndeterminate="{Binding IsLoading}" 
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding StatusMessage}"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding IsInitialized, Converter={StaticResource InitializedStatusConverter}}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>