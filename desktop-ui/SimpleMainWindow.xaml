<Window x:Class="SecureCloud.Desktop.SimpleMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SecureCloud - Encrypted Cloud Storage" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Simple Toolbar -->
        <ToolBar Grid.Row="0" Margin="5">
            <Button Content="Test" Click="TestButton_Click" Padding="10,5" Margin="2"/>
            <Button Content="Initialize" Click="InitializeButton_Click" Padding="10,5" Margin="2"/>
            <Separator/>
            <Button Content="Add File" Click="AddFileButton_Click" Padding="10,5" Margin="2"/>
            <Button Content="Settings" Click="SettingsButton_Click" Padding="10,5" Margin="2"/>
        </ToolBar>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Margin="5">
            <TabItem Header="Files">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- File List -->
                    <DataGrid Grid.Row="0" Name="FilesDataGrid" 
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding SizeFormatted}" Width="100"/>
                            <DataGridTextColumn Header="Encrypted Size" Binding="{Binding EncryptedSizeFormatted}" Width="120"/>
                            <DataGridTextColumn Header="Encrypted" Binding="{Binding IsEncrypted}" Width="80"/>
                            <DataGridTextColumn Header="Uploaded" Binding="{Binding UploadedAt}" Width="150"/>
                            <DataGridTextColumn Header="Message ID" Binding="{Binding MessageId}" Width="100"/>
                            <DataGridTemplateColumn Header="Actions" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Download" 
                                                Click="DownloadButton_Click"
                                                Tag="{Binding}"
                                                Padding="5,2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <!-- Status Text -->
                    <TextBlock Grid.Row="1" Name="FileStatusText"
                               Text="No files uploaded yet. Click 'Add File' to upload your first file."
                               HorizontalAlignment="Center" 
                               Margin="10"
                               FontStyle="Italic"
                               Foreground="Gray"/>
                </Grid>
            </TabItem>
            
            <TabItem Header="Status">
                <Grid Margin="10">
                    <StackPanel>
                        <TextBlock Name="StatusText" Text="Status: Ready" FontSize="14" Margin="0,5"/>
                        <TextBlock Name="FilesCountText" Text="Files: 0" FontSize="14" Margin="0,5"/>
                        <TextBlock Name="StorageText" Text="Storage: 0 bytes" FontSize="14" Margin="0,5"/>
                        <TextBlock Name="BotInfoText" Text="Bot: Not connected" FontSize="14" Margin="0,5"/>
                        <TextBlock Name="ChannelInfoText" Text="Channel: Not connected" FontSize="14" Margin="0,5"/>
                        
                        <Separator Margin="0,10"/>
                        
                        <TextBlock Text="Recent Activity:" FontWeight="Bold" FontSize="14" Margin="0,10,0,5"/>
                        <ScrollViewer Height="200" VerticalScrollBarVisibility="Auto">
                            <TextBlock Name="ActivityLogText" 
                                       Text="No activity yet."
                                       TextWrapping="Wrap"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Foreground="DarkGreen"/>
                        </ScrollViewer>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="Ready"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="SecureCloud v1.0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>