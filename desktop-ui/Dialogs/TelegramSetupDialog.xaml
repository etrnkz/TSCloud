<Window x:Class="TSCloud.Desktop.Dialogs.TelegramSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Telegram Bot Setup - TSCloud" 
        Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{DynamicResource ModernWindowStyle}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="🤖 Telegram Bot Setup" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Style="{DynamicResource PrimaryTextStyle}"/>
            <TextBlock Text="Set up your personal Telegram bot for secure cloud storage" 
                       FontSize="14" 
                       HorizontalAlignment="Center" 
                       Margin="0,5,0,0"
                       Style="{DynamicResource SecondaryTextStyle}"/>
        </StackPanel>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Step 1: Create Bot -->
                <Border Background="{DynamicResource CardBackgroundBrush}" 
                        BorderBrush="{DynamicResource BorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="15" 
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="📋 Step 1: Create Your Telegram Bot" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"
                                   Style="{DynamicResource PrimaryTextStyle}"/>
                        
                        <TextBlock TextWrapping="Wrap" 
                                   Margin="0,0,0,10"
                                   Style="{DynamicResource SecondaryTextStyle}">
                            <Run Text="1. Open Telegram and search for "/>
                            <Run Text="@BotFather" FontWeight="Bold"/>
                            <LineBreak/>
                            <Run Text="2. Send "/>
                            <Run Text="/newbot" FontWeight="Bold"/>
                            <Run Text=" command"/>
                            <LineBreak/>
                            <Run Text="3. Choose a name for your bot (e.g., 'My TSCloud Bot')"/>
                            <LineBreak/>
                            <Run Text="4. Choose a username ending with 'bot' (e.g., 'myTSCloud_bot')"/>
                            <LineBreak/>
                            <Run Text="5. Copy the bot token that BotFather gives you"/>
                        </TextBlock>
                        
                        <Button Content="📱 Open Telegram Web" 
                                Click="OpenTelegramWeb_Click"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Step 2: Bot Token -->
                <Border Background="{DynamicResource CardBackgroundBrush}" 
                        BorderBrush="{DynamicResource BorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="15" 
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🔑 Step 2: Enter Your Bot Token" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"
                                   Style="{DynamicResource PrimaryTextStyle}"/>
                        
                        <TextBlock Text="Paste the bot token from BotFather here:" 
                                   Margin="0,0,0,5"
                                   Style="{DynamicResource SecondaryTextStyle}"/>
                        
                        <TextBox Name="BotTokenTextBox" 
                                 Height="35"
                                 Padding="10,8"
                                 FontFamily="Consolas"
                                 Style="{DynamicResource ModernTextBoxStyle}"
                                 TextChanged="BotTokenTextBox_TextChanged"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Name="TestBotButton" 
                                    Content="🧪 Test Bot Connection" 
                                    Click="TestBotButton_Click"
                                    IsEnabled="False"
                                    Style="{DynamicResource SecondaryButtonStyle}"/>
                            <TextBlock Name="BotTestStatus" 
                                       Margin="10,0,0,0" 
                                       VerticalAlignment="Center"
                                       Style="{DynamicResource SecondaryTextStyle}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Step 3: Create Channels -->
                <Border Background="{DynamicResource CardBackgroundBrush}" 
                        BorderBrush="{DynamicResource BorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="15" 
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="📺 Step 3: Create Storage Channels" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"
                                   Style="{DynamicResource PrimaryTextStyle}"/>
                        
                        <TextBlock TextWrapping="Wrap" 
                                   Margin="0,0,0,10"
                                   Style="{DynamicResource SecondaryTextStyle}">
                            <Run Text="Create private channels for storing your files:"/>
                            <LineBreak/>
                            <Run Text="1. In Telegram, tap the "/>
                            <Run Text="pencil icon" FontWeight="Bold"/>
                            <Run Text=" → "/>
                            <Run Text="New Channel" FontWeight="Bold"/>
                            <LineBreak/>
                            <Run Text="2. Name it something like 'My TSCloud Storage'"/>
                            <LineBreak/>
                            <Run Text="3. Make it "/>
                            <Run Text="Private" FontWeight="Bold"/>
                            <Run Text=" (very important!)"/>
                            <LineBreak/>
                            <Run Text="4. Add your bot as an admin with 'Post Messages' permission"/>
                            <LineBreak/>
                            <Run Text="5. Repeat to create 2-3 backup channels for redundancy"/>
                        </TextBlock>
                        
                        <Button Content="📖 Detailed Guide" 
                                Click="ShowChannelGuide_Click"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Step 4: Channel IDs -->
                <Border Background="{DynamicResource CardBackgroundBrush}" 
                        BorderBrush="{DynamicResource BorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="15" 
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🆔 Step 4: Get Channel IDs" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,10"
                                   Style="{DynamicResource PrimaryTextStyle}"/>
                        
                        <TextBlock TextWrapping="Wrap" 
                                   Margin="0,0,0,10"
                                   Style="{DynamicResource SecondaryTextStyle}">
                            <Run Text="Forward any message from each channel to "/>
                            <Run Text="@userinfobot" FontWeight="Bold"/>
                            <Run Text=" to get the channel ID"/>
                        </TextBlock>
                        
                        <Button Name="AutoDetectChannelsButton" 
                                Content="🔍 Auto-Detect Channels" 
                                Click="AutoDetectChannels_Click"
                                IsEnabled="False"
                                Style="{DynamicResource ModernButtonStyle}"
                                Margin="0,0,0,10"/>
                        
                        <DataGrid Name="ChannelsDataGrid" 
                                  Height="150"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="True"
                                  CanUserDeleteRows="True"
                                  Style="{DynamicResource ModernDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Channel Name" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Channel ID" Binding="{Binding Id}" Width="150"/>
                                <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="80"/>
                                <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        
                        <Button Name="TestChannelsButton" 
                                Content="🧪 Test All Channels" 
                                Click="TestChannelsButton_Click"
                                IsEnabled="False"
                                Style="{DynamicResource SecondaryButtonStyle}"
                                Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Status Panel -->
                <Border Name="StatusPanel" 
                        Background="{DynamicResource InfoBackgroundBrush}" 
                        BorderBrush="{DynamicResource InfoBorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Padding="15" 
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Name="StatusTitle" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,5"
                                   Style="{DynamicResource PrimaryTextStyle}"/>
                        <TextBlock Name="StatusMessage" 
                                   TextWrapping="Wrap"
                                   Style="{DynamicResource SecondaryTextStyle}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="❌ Cancel" 
                    Click="CancelButton_Click" 
                    Style="{DynamicResource SecondaryButtonStyle}" 
                    Margin="0,0,10,0"/>
            <Button Name="SaveButton" 
                    Content="💾 Save Configuration" 
                    Click="SaveButton_Click" 
                    IsEnabled="False"
                    Style="{DynamicResource ModernButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>