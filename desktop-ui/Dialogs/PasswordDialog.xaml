<Window x:Class="TSCloud.Desktop.Dialogs.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TSCloud - Master Password" 
        Height="250" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="🔐 TSCloud Encryption" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" 
                   Text="Enter your master password to enable zero-knowledge encryption:" 
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" 
                   Text="Master Password:" 
                   Margin="0,5"/>
        
        <PasswordBox Grid.Row="3" 
                     Name="PasswordBox" 
                     Margin="0,5,0,10"
                     FontSize="14"/>

        <TextBlock Grid.Row="4" 
                   Text="• Files will be encrypted with XChaCha20-Poly1305&#10;• Password is used for Argon2id key derivation&#10;• Same password works across all devices&#10;• No password recovery - keep it safe!"
                   FontSize="11"
                   Foreground="Gray"
                   TextWrapping="Wrap"
                   Margin="0,5"/>

        <StackPanel Grid.Row="5" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,10,0,0">
            <Button Name="OkButton" 
                    Content="Enable Encryption" 
                    Padding="15,5" 
                    Margin="0,0,10,0" 
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button Name="SkipButton" 
                    Content="Skip (No Encryption)" 
                    Padding="15,5" 
                    Click="SkipButton_Click"/>
        </StackPanel>
    </Grid>
</Window>