<Window x:Class="SecureCloud.Desktop.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Encryption Password" 
        Height="200" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="🔐 SecureCloud Encryption" 
                   FontSize="16" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" 
                   Text="Enter a master password to encrypt your files:" 
                   TextWrapping="Wrap" 
                   Margin="0,0,0,10"/>

        <PasswordBox Grid.Row="2" 
                     Name="PasswordBox" 
                     Margin="0,0,0,10"
                     FontSize="14"
                     Padding="5"/>

        <TextBlock Grid.Row="3" 
                   Text="⚠️ Important: This password cannot be recovered. Make sure to remember it or store it safely."
                   TextWrapping="Wrap" 
                   FontSize="11"
                   Foreground="DarkOrange"
                   Margin="0,0,0,10"/>

        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button Content="Skip (No Encryption)" 
                    Click="SkipButton_Click" 
                    Padding="10,5" 
                    Margin="0,0,10,0"/>
            <Button Content="Enable Encryption" 
                    Click="OkButton_Click" 
                    Padding="10,5" 
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>